  <article xml:id="shorttitlelowercase">
    <title>The title of my groundbreaking paper</title>

    <p>
      <ol>
        <li>
          Find the eigenvalues and eigenspaces for the following matrix.
          <md>
            \begin{bmatrix}
              2 \amp 1  \amp 0\\
              1 \amp 2 \amp 1\\
              1 \amp 1 \amp 3\\
            \end{bmatrix}
          </md>
          
        </li>

      </ol>
    </p>
  </article>

</pretext>
